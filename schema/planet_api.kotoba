// Planet_api clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace planet_api {

    entity Object {
        id: string @unique
        designator: string
        type: string
        source: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Position {
        id: string @unique
        objectId: string
        lat: float
        lon: float
        altitudeM: float
        asOf: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Observation {
        id: string @unique
        objectId: string
        parameter: string
        value: float
        observedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Scene {
        id: string @unique
        satellite: string
        sceneId: string
        cloudCover: float
        capturedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Float {
        id: string @unique
        wmoId: string
        lat: float
        lon: float
        parkDepthM: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Station {
        id: string @unique
        stationId: string
        name: string
        network: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
